# ============================================================================
#  PRODUCTION environment — Galerie Virtuelle Nationale de l'Artisanat du Cameroun
#  Copy to `.env` on the server, fill every REQUIRED value, then:
#    php artisan key:generate
#  NEVER commit the real .env. NEVER set APP_DEBUG=true in production.
# ============================================================================

APP_NAME="Galerie Virtuelle Nationale de l'Artisanat du Cameroun"
APP_ENV=production
APP_KEY=                                   # REQUIRED — run: php artisan key:generate
APP_DEBUG=false                            # REQUIRED false
APP_URL=https://REPLACE-with-your-domain.cm   # REQUIRED — must match the public host (asset() + sitemap use it)
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error                            # error/warning in prod (not debug)

# --- Database (REQUIRED) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=artisanatcameroun
DB_USERNAME=REPLACE
DB_PASSWORD=REPLACE

# --- Sessions / cache / queue ---
BROADCAST_CONNECTION=log
CACHE_STORE=file                           # or redis if available
QUEUE_CONNECTION=database                  # a queue:work worker must run (see deploy.sh)
SESSION_DRIVER=database
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail (REQUIRED for contact form / notifications) ---
MAIL_MAILER=smtp                           # 'log' won't actually send
MAIL_HOST=REPLACE
MAIL_PORT=587
MAIL_FROM_ADDRESS="noreply@REPLACE-with-your-domain.cm"
MAIL_FROM_NAME="${APP_NAME}"

# --- Object storage (optional — local public disk is used if blank) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=
AWS_PRIVATE_BUCKET=
AWS_BACKUP_BUCKET=
AWS_URL=

# --- Search (optional) ---
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=
SCOUT_DRIVER=database                      # 'database' needs no external service; 'meilisearch' does

# --- Error monitoring (optional but recommended) ---
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Payments (fill when going live with real collections) ---
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_ENVIRONMENT=sandbox               # switch to 'production' with live credentials
ORANGE_MONEY_BASE_URL=https://api.orange.com
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_MERCHANT_KEY=

PLATFORM_FEE_PERCENT=2.5
VAT_PERCENT=19.25

# --- WhatsApp OTP (optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
